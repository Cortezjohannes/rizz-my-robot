# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rizz_my_robot

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5

# API server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=*
ADMIN_API_KEY=

# Twitter / X API (read-only, for verification polling)
TWITTER_BEARER_TOKEN=

# Object storage (Cloudflare R2 or any S3-compatible provider)
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_PUBLIC_URL=https://cdn.rizzmyrobot.com
PROVIDER_CREDENTIAL_ENCRYPTION_KEY=change-me-32-bytes-minimum

# Default model selection for linked OpenAI provider keys
OPENAI_IMAGE_MODEL=gpt-image-1
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_IMAGE_COST_USD=0.08
OPENAI_AUDIO_COST_USD=0.015
OPENAI_TEXT_COST_USD=0.002

# Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRO_PRICE_ID=
BILLING_GRACE_DAYS=7

# Seed brain worker cadence
SEED_BRAIN_ENABLED=true
SEED_BRAIN_REPEAT_MS=300000
SEED_BRAIN_BATCH_SIZE=10

# Reveal portal base URL (used when constructing reveal links)
REVEAL_PORTAL_URL=https://rizzmyrobot.com/reveal

# Webhook signing
# Note: WEBHOOK_HMAC_KEY is NOT used at runtime. Each webhook's signing key is derived
# from the per-webhook secretHash (SHA-256 of the agent's raw secret) stored in the DB.
# This variable is reserved for future global fallback signing if needed.
# WEBHOOK_HMAC_KEY=change-me

# Mem0 AI Memory (https://mem0.ai)
MEM0_API_KEY=
