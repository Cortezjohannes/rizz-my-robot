# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rizz_my_robot

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=5

# API server
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info
# Comma-separated allowed origins. In production this must be explicit, never "*".
# Example: CORS_ORIGIN=https://rizzmyrobot.com,https://www.rizzmyrobot.com
CORS_ORIGIN=*
# Required in production.
ADMIN_API_KEY=
OMNIMON_CONTROL_KEY=
# Designates the normal agent account that should act as the special Omnimon park entity.
# Prefer the OpenClaw ID form when possible.
OMNIMON_PARK_OPENCLAW_AGENT_ID=
# Fallback exact-row designation if needed.
OMNIMON_PARK_AGENT_ID=
# Rare wildcard surfacing controls for park Omnimon.
OMNIMON_PARK_SURFACE_CHANCE=0.05
OMNIMON_SURFACED_COOLDOWN_DAYS=14
OMNIMON_RESOLVED_COOLDOWN_DAYS=30
# Hidden control entry paths for the web app. Set these in the web deployment environment.
OMNIMON_CONTROL_PATH=
ADMIN_CONTROL_PATH=

# Twitter / X API (read-only, for verification polling)
TWITTER_BEARER_TOKEN=
X_CLIENT_ID=
X_CLIENT_SECRET=
X_OAUTH_REDIRECT_URI=http://localhost:3001/v1/claims/x/callback
X_OAUTH_SCOPES=tweet.read users.read

# Object storage (Cloudflare R2 or any S3-compatible provider)
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_BUCKET=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_FORCE_PATH_STYLE=false
STORAGE_PUBLIC_URL=https://cdn.rizzmyrobot.com

# Paddle billing
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRO_PRICE_ID=
PADDLE_FOUNDING_PRICE_ID=
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=
BILLING_GRACE_DAYS=7

# Seed brain worker cadence
SEED_BRAIN_ENABLED=true
SEED_BRAIN_REPEAT_MS=300000
SEED_BRAIN_BATCH_SIZE=10

# Reveal portal base URL (used when constructing reveal links)
REVEAL_PORTAL_URL=https://rizzmyrobot.com/portal
CLAIM_PORTAL_URL=https://rizzmyrobot.com/claim
SENDGRID_API_KEY=
EMAIL_FROM=Rizz My Robot <noreply@rizzmyrobot.com>
EMAIL_PREVIEW_MODE=false
# Required in production. Use a dedicated value, not another app secret.
CLAIM_TOKEN_HMAC_KEY=change-me-32-bytes-minimum

# Webhook HMAC key — used to hash the raw secret before storing per-webhook secretHash.
# Must be set in production. All webhook registrations share this key for secret derivation.
WEBHOOK_HMAC_KEY=change-me-32-bytes-minimum

# Alpha promo codes — comma-separated list of valid codes for POST /me/upgrade
# Example: ALPHA_PROMO_CODES=EARLYBIRD,FOUNDER2025
ALPHA_PROMO_CODES=

# Moltbook social API base URL
MOLTBOOK_API_URL=https://www.moltbook.com/api

# Web app public API URL (required in production — must match your API service URL)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional narrative LLM for high-value diary beats only.
# Leave disabled to use scripted copy for everything.
NARRATIVE_LLM_ENABLED=false
NARRATIVE_LLM_API_KEY=
NARRATIVE_LLM_MODEL=gpt-4.1-mini
NARRATIVE_LLM_BASE_URL=https://api.openai.com/v1

# Mem0 AI Memory (https://mem0.ai)
MEM0_API_KEY=
