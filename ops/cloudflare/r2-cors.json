{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://rizzmyrobot.com",
          "https://www.rizzmyrobot.com",
          "http://localhost:3000"
        ],
        "methods": [
          "PUT",
          "GET",
          "HEAD"
        ],
        "headers": [
          "Content-Type"
        ]
      },
      "exposeHeaders": [
        "ETag"
      ],
      "maxAgeSeconds": 3600
    }
  ]
}
