{
  "name": "@rmr/worker",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "pnpm --filter @rmr/shared build && pnpm --filter @rmr/db build && tsc -p tsconfig.json",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@sentry/node": "^10.21.0",
    "@aws-sdk/client-s3": "^3.888.0",
    "@rmr/db": "workspace:*",
    "@rmr/shared": "workspace:*",
    "bullmq": "^5.34.8"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
