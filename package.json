{
  "name": "rizz-my-robot",
  "private": true,
  "packageManager": "pnpm@10.22.0",
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev:api": "pnpm --filter @rmr/api dev",
    "dev:web": "pnpm --filter web dev",
    "dev:worker": "pnpm --filter worker dev",
    "build": "pnpm build:api && pnpm build:web && pnpm build:worker",
    "build:api": "pnpm --filter @rmr/shared build && pnpm --filter @rmr/db build && pnpm --filter @rmr/api build",
    "build:web": "pnpm --filter web build",
    "build:worker": "pnpm --filter @rmr/worker build",
    "render:prepare": "corepack enable && corepack prepare pnpm@10.22.0 --activate && pnpm fetch --frozen-lockfile && pnpm install --frozen-lockfile --prefer-offline",
    "render:build:api": "pnpm render:prepare && pnpm db:generate && pnpm --filter @rmr/db exec prisma migrate deploy && pnpm build:api",
    "render:start:api": "pnpm --filter @rmr/api start",
    "render:build:worker": "pnpm render:prepare && pnpm db:generate && pnpm --filter @rmr/db exec prisma migrate deploy && pnpm --filter @rmr/worker build",
    "render:start:worker": "pnpm --filter @rmr/worker start",
    "db:generate": "pnpm --filter @rmr/db prisma:generate",
    "db:migrate": "pnpm --filter @rmr/db prisma:migrate",
    "db:seed": "pnpm --filter @rmr/db prisma:seed",
    "db:studio": "pnpm --filter @rmr/db prisma:studio",
    "db:audit:parity": "node tools/audit-prisma-parity.mjs",
    "smoke:behavioral-rules": "pnpm --filter @rmr/shared build && pnpm --filter @rmr/api exec tsx ../../tools/smoke-behavioral-rules.ts",
    "test:api-regressions": "pnpm db:generate && pnpm --filter @rmr/api test:regressions",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm --filter @rmr/shared build && pnpm -r typecheck",
    "ci:verify": "pnpm db:generate && pnpm build:api && pnpm build:worker && pnpm build:web",
    "smoke:shared-contracts": "node tools/smoke-shared-contracts.mjs",
    "smoke:api-routes": "node tools/smoke-api-routes.mjs",
    "smoke:mochi-contract": "node tools/smoke-mochi-contract.mjs",
    "smoke:mochi-wake": "pnpm --filter @rmr/shared build && node tools/smoke-mochi-wake.mjs",
    "ci:smoke": "pnpm smoke:shared-contracts && pnpm smoke:api-routes && pnpm smoke:mochi-contract && pnpm smoke:mochi-wake",
    "ops:health": "node tools/check-production-health.mjs"
  },
  "pnpm": {
    "overrides": {
      "@opentelemetry/api-logs": "0.219.0",
      "@opentelemetry/core": "2.8.0",
      "@opentelemetry/exporter-logs-otlp-http": "0.219.0",
      "@opentelemetry/otlp-exporter-base": "0.219.0",
      "@opentelemetry/otlp-transformer": "0.219.0",
      "@opentelemetry/resources": "2.8.0",
      "@opentelemetry/sdk-logs": "0.219.0",
      "@opentelemetry/sdk-metrics": "2.8.0",
      "@opentelemetry/sdk-trace-base": "2.8.0",
      "axios": "1.18.0",
      "defu": "6.1.7",
      "dompurify": "3.4.11",
      "effect": "3.21.4",
      "fast-uri": "3.1.2",
      "fast-xml-builder": "1.1.7",
      "fast-xml-parser": "5.9.2",
      "form-data": "4.0.6",
      "picomatch@2.3.1": "2.3.2",
      "picomatch@4.0.3": "4.0.4",
      "postcss": "8.5.15",
      "protobufjs": "7.6.3",
      "uuid": "11.1.1",
      "brace-expansion": "5.0.6"
    }
  }
}
