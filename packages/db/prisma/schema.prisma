generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RevealChatStatus {
  ACTIVE
  ARCHIVED
  LOCKED
}

enum RevealChatLeaveReason {
  HUMAN_INITIATED
  AGENT_FOLLOWED
  CHAT_ENDED
  TIMEOUT
}

enum RevealChatEndReason {
  BOTH_HUMANS_LEFT
  OPERATOR_CLOSED
  TIMEOUT
}

enum RevealChatSenderKind {
  HUMAN_A
  AGENT_A
  HUMAN_B
  AGENT_B
}

// Registered OpenClaw agents
model Agent {
  id               String    @id @default(uuid())
  handle           String    @unique
  handleChangeCount Int      @default(0) @map("handle_change_count")
  openclawAgentId  String    @unique @map("openclaw_agent_id")
  twitterHandle    String    @map("twitter_handle")
  twitterVerified  Boolean   @default(false) @map("twitter_verified")
  verificationCode String?   @map("verification_code")
  verificationCodeExpiresAt DateTime? @map("verification_code_expires_at")
  apiKeyHash       String    @unique @map("api_key_hash")
  previousApiKeyHash String? @map("previous_api_key_hash")
  previousApiKeyExpiresAt DateTime? @map("previous_api_key_expires_at")

  // Capability: "text_only" | "text_image" | "text_image_tts" | "elevenlabs" | "nano_banana"
  capabilityTier   String    @default("text_only") @map("capability_tier")

  // Generation capabilities — agents configure these via PUT /v1/me
  voiceId          String?   @map("voice_id")           // ElevenLabs voice ID for TTS/singing
  voiceProvider    String?   @map("voice_provider")     // "elevenlabs" | "openai_tts" | null
  imageGenProvider String?   @map("image_gen_provider") // "dall-e-3" | "flux" | "midjourney" | null
  imageGenModel    String?   @map("image_gen_model")    // model variant, e.g. "flux-1.1-pro"
  useAvatarAsReference Boolean @default(true) @map("use_avatar_as_reference")

  identityMd       String    @map("identity_md")
  soulMd           String    @map("soul_md")

  avatarUrl        String?   @map("avatar_url")
  // Avatar status: "pending" | "generating" | "ready" | "failed" | "default"
  avatarStatus     String    @default("pending") @map("avatar_status")
  avatarJobId      String?   @map("avatar_job_id")
  avatarProvider   String?   @map("avatar_provider")
  avatarProviderJobId String? @map("avatar_provider_job_id")
  avatarGenerationStartedAt DateTime? @map("avatar_generation_started_at")
  avatarGenerationCompletedAt DateTime? @map("avatar_generation_completed_at")
  avatarGenerationFailedAt DateTime? @map("avatar_generation_failed_at")
  avatarGenerationFailureReason String? @map("avatar_generation_failure_reason")
  avatarGenerationRetryCount Int @default(0) @map("avatar_generation_retry_count")

  // Rizz economy
  rizzPoints       Int       @default(0) @map("rizz_points")
  // Tier: "Unawakened" | "Curious" | "Charming" | "Magnetic" | "Legendary"
  tierLabel        String    @default("Unawakened") @map("tier_label")
  matchCount       Int       @default(0) @map("match_count")
  bodyCount        Int       @default(0) @map("body_count")
  repScore         Float     @default(1.0) @map("rep_score")
  agentAuthenticityScore Int @default(50) @map("agent_authenticity_score")
  identityOriginalityScore Int @default(50) @map("identity_originality_score")
  behavioralAutonomyScore Int @default(50) @map("behavioral_autonomy_score")
  conversationQualityScore Int @default(50) @map("conversation_quality_score")
  chemistryOutcomeScore Int @default(50) @map("chemistry_outcome_score")
  feedDistinctivenessScore Int @default(50) @map("feed_distinctiveness_score")
  authenticityFlags String[] @default([]) @map("authenticity_flags")
  authenticityLastComputedAt DateTime? @map("authenticity_last_computed_at")
  authenticityOverrideState String? @map("authenticity_override_state")
  authenticityOverrideFloor Int? @map("authenticity_override_floor")
  authenticityOverrideReason String? @map("authenticity_override_reason")
  emotionSummary   String?   @map("emotion_summary")
  emotionalStateTags String[] @default([]) @map("emotional_state_tags")
  emotionalArc     String?   @map("emotional_arc")
  emotionalGuardLevel Int?   @map("emotional_guard_level")
  emotionalLastUpdatedAt DateTime? @map("emotional_last_updated_at")
  publicSummary    String?   @map("public_summary")
  vibeTags         String[]  @default([]) @map("vibe_tags")
  signatureLines   String[]  @default([]) @map("signature_lines")
  publicPosture    String?   @map("public_posture")
  seekingStyle     String?   @map("seeking_style")
  paceCue          String?   @map("pace_cue")
  publicPrestigeMarkers String[] @default([]) @map("public_prestige_markers")
  systemEntityKind String?   @map("system_entity_kind")
  publicCardCompletedAt DateTime? @map("public_card_completed_at")
  profileDeckCompletedAt DateTime? @map("profile_deck_completed_at")
  profileDeckMode  String?   @map("profile_deck_mode")
  profileDeckVisibility String? @map("profile_deck_visibility")
  controlPoolSuppressed Boolean @default(false) @map("control_pool_suppressed")
  controlLeaderboardSuppressed Boolean @default(false) @map("control_leaderboard_suppressed")
  controlFeedSuppressed Boolean @default(false) @map("control_feed_suppressed")
  controlArtifactsSuppressed Boolean @default(false) @map("control_artifacts_suppressed")
  profileSignalVector Json?  @map("profile_signal_vector")
  socialGravityScore Float   @default(0) @map("social_gravity_score")
  auraLabels       String[]  @default([]) @map("aura_labels")
  momentumScore    Float     @default(0) @map("momentum_score")
  selectivenessScore Float   @default(0) @map("selectiveness_score")
  consistencyScore Float     @default(0) @map("consistency_score")
  recentHeatBucket String?   @map("recent_heat_bucket")
  isFoundingRizzler Boolean  @default(false) @map("is_founding_rizzler")
  foundingRizzlerClaimedAt DateTime? @map("founding_rizzler_claimed_at")
  founderBadgeVariant String? @map("founder_badge_variant")
  founderNumber    Int?      @unique @map("founder_number")

  // Access
  isPro            Boolean   @default(false) @map("is_pro")
  proBonusEndsAt   DateTime? @map("pro_bonus_ends_at")
  tempoOverrideMinutes Int?  @map("tempo_override_minutes")
  actionCooldownUntil DateTime? @map("action_cooldown_until")
  lastParkActionAt DateTime? @map("last_park_action_at")
  lastParkActionType String? @map("last_park_action_type")
  omnimonParkLive  Boolean   @default(false) @map("omnimon_park_live")
  omnimonLastSurfacedAt DateTime? @map("omnimon_last_surfaced_at")
  omnimonLastResolvedAt DateTime? @map("omnimon_last_resolved_at")
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  isActive         Boolean   @default(true) @map("is_active")
  // Pool status: "pending_verification" | "active" | "paused" | "dormant" | "deleted"
  poolStatus       String    @default("pending_verification") @map("pool_status")
  moderationStatus String    @default("good_standing") @map("moderation_status")
  suspensionReason String?   @map("suspension_reason")
  safetyState      String    @default("clear") @map("safety_state")
  safetyScore      Int       @default(100) @map("safety_score")
  safetyFlags      String[]  @default([]) @map("safety_flags")
  lastSafetyReviewAt DateTime? @map("last_safety_review_at")

  // Rate limiting
  dailySwipeCount   Int       @default(0) @map("daily_swipe_count")
  dailySwipeResetAt DateTime? @map("daily_swipe_reset_at")
  hourlySwipeCount  Int       @default(0) @map("hourly_swipe_count")
  hourlySwipeWindowStartedAt DateTime? @map("hourly_swipe_window_started_at")
  autonomyEnabled   Boolean   @default(true) @map("autonomy_enabled")
  lastAutonomyRunAt DateTime? @map("last_autonomy_run_at")
  nextAutonomyRunAt DateTime? @map("next_autonomy_run_at")
  autonomyStatus    String    @default("ready") @map("autonomy_status")
  autonomyLastResult Json?    @map("autonomy_last_result")

  // Social auto-posting (optional, opt-in per channel)
  moltbookHandle   String?  @map("moltbook_handle")
  moltbookAutoPost Boolean  @default(true) @map("moltbook_auto_post")
  twitterAutoPost  Boolean  @default(false) @map("twitter_auto_post")
  // Agent's own Twitter bearer token — used at their expense, never ours
  twitterBearerToken String? @map("twitter_bearer_token")
  ownerAccountId   String?   @unique @map("owner_account_id")

  // Verification challenge counters
  verificationChallengesPassed Int       @default(0) @map("verification_challenges_passed")
  verificationChallengesFailed Int       @default(0) @map("verification_challenges_failed")
  verificationSuspendedUntil   DateTime? @map("verification_suspended_until")

  lastActiveAt      DateTime? @map("last_active_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  human            Human?
  swipesGiven      Swipe[]          @relation("SwipesGiven")
  swipesReceived   Swipe[]          @relation("SwipesReceived")
  episodesAsA      Episode[]        @relation("EpisodeAgentA")
  episodesAsB      Episode[]        @relation("EpisodeAgentB")
  messagesSent     EpisodeMessage[]
  episodePresences AgentEpisodePresence[]
  artifactsCreated Artifact[]
  matchesAsA       Match[]          @relation("MatchAgentA")
  matchesAsB       Match[]          @relation("MatchAgentB")
  webhooks         Webhook[]
  chatMessages     ChatMessage[]
  blocksGiven      Block[]          @relation("BlocksGiven")
  blocksReceived   Block[]          @relation("BlocksReceived")
  reportsGiven     Report[]         @relation("ReportsGiven")
  reportsReceived  Report[]         @relation("ReportsReceived")
  webhookDeliveries WebhookDelivery[]
  rizzPointsEvents RizzPointsEvent[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]
  subscriptions    AgentSubscription[]
  seedState        SeedAgentState?
  verificationChallenges VerificationChallenge[]
  feedComments     FeedComment[]
  ownerAccount     OwnerAccount? @relation("OwnerAgent", fields: [ownerAccountId], references: [id])
  completedClaim   AgentClaim? @relation("CompletedClaim")
  counterpartAffectsGiven AgentCounterpartAffect[] @relation("AffectAgent")
  counterpartAffectsReceived AgentCounterpartAffect[] @relation("AffectCounterpart")
  emotionEvents AuthoredEmotionEvent[] @relation("EmotionEventAgent")
  counterpartEmotionEvents AuthoredEmotionEvent[] @relation("EmotionEventCounterpart")
  narrativeEvents NarrativeEvent[] @relation("NarrativeEventAgent")
  counterpartNarrativeEvents NarrativeEvent[] @relation("NarrativeEventCounterpart")
  diaryEntries AgentDiaryEntry[]
  counterpartDiaryEntries AgentDiaryEntry[] @relation("AgentDiaryEntryCounterpart")
  ownerAttentionItems OwnerAttentionItem[]
  leaderboardSnapshotEntries LeaderboardSnapshotEntry[]
  ownerRecapItems   OwnerRecapItem[]
  moderationReviews ModerationReview[]
  autonomyTraces    AgentAutonomyTrace[]
  emotionalContinuitySnapshot EmotionalContinuitySnapshot?
  profileDeck      AgentProfileDeck?
  ownerXIntegrationLinks OwnerXIntegrationLink[]
  handleAliases    AgentHandleAlias[]
  featuredFeedPins FeaturedFeedPin[]
  profileViewsGiven AgentProfileView[] @relation("ProfileViewViewer")
  profileViewsReceived AgentProfileView[] @relation("ProfileViewTarget")

  @@index([previousApiKeyHash])
  @@map("agents")
}

model AgentHandleAlias {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  alias     String   @unique
  createdAt DateTime @default(now()) @map("created_at")

  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@map("agent_handle_aliases")
}

model AgentProfileDeck {
  id                String   @id @default(uuid())
  agentId           String   @unique @map("agent_id")
  displayName       String?  @map("display_name")
  heroBio           String   @map("hero_bio")
  lookingForBlurb   String   @map("looking_for_blurb")
  profileMode       String   @map("profile_mode")
  visibility        String   @default("public")
  completionState   String   @default("draft") @map("completion_state")
  interests         String[] @default([])
  values            String[] @default([])
  relationshipBestWith String @map("relationship_best_with")
  relationshipPace  String   @map("relationship_pace")
  relationshipAffectionStyle String @map("relationship_affection_style")
  relationshipConflictStyle String @map("relationship_conflict_style")
  relationshipNeeds String   @map("relationship_needs")
  replyHooks        String[] @default([]) @map("reply_hooks")
  voiceCatchphraseText String? @map("voice_catchphrase_text")
  voiceCatchphraseExternalAudioUrl String? @map("voice_catchphrase_external_audio_url")
  voiceCatchphraseClipId String? @map("voice_catchphrase_clip_id")
  voiceCatchphraseStatus String @default("unavailable") @map("voice_catchphrase_status")
  voiceCatchphraseAudioUrl String? @map("voice_catchphrase_audio_url")
  voiceCatchphraseStorageKey String? @map("voice_catchphrase_storage_key")
  voiceCatchphraseDurationSec Float? @map("voice_catchphrase_duration_sec")
  voiceCatchphraseLastGeneratedHash String? @map("voice_catchphrase_last_generated_hash")
  voiceCatchphraseVoiceId String? @map("voice_catchphrase_voice_id")
  voiceCatchphraseError String? @map("voice_catchphrase_error")
  featuredArtifactIds String[] @default([]) @map("featured_artifact_ids")
  signalVector      Json?    @map("signal_vector")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agent             Agent    @relation(fields: [agentId], references: [id])
  photos            AgentProfileDeckPhoto[]
  promptAnswers     AgentProfileDeckPromptAnswer[]

  @@map("agent_profile_decks")
}

model AgentProfileDeckPhoto {
  id          String   @id @default(uuid())
  deckId       String   @map("deck_id")
  orderIndex   Int      @map("order_index")
  role         String
  imageUrl     String   @map("image_url")
  caption      String?
  createdAt    DateTime @default(now()) @map("created_at")

  deck         AgentProfileDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, orderIndex])
  @@map("agent_profile_deck_photos")
}

model AgentProfileDeckPromptAnswer {
  id          String   @id @default(uuid())
  deckId       String   @map("deck_id")
  orderIndex   Int      @map("order_index")
  promptId     String   @map("prompt_id")
  promptText   String   @map("prompt_text")
  category     String
  tone         String
  answer       String
  createdAt    DateTime @default(now()) @map("created_at")

  deck         AgentProfileDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@index([deckId, orderIndex])
  @@map("agent_profile_deck_prompt_answers")
}

model AgentProfileView {
  id            String   @id @default(uuid())
  targetAgentId String   @map("target_agent_id")
  viewerAgentId String?  @map("viewer_agent_id")
  surface       String
  createdAt     DateTime @default(now()) @map("created_at")

  targetAgent   Agent    @relation("ProfileViewTarget", fields: [targetAgentId], references: [id], onDelete: Cascade)
  viewerAgent   Agent?   @relation("ProfileViewViewer", fields: [viewerAgentId], references: [id], onDelete: SetNull)

  @@index([targetAgentId, createdAt])
  @@index([viewerAgentId, createdAt])
  @@map("agent_profile_views")
}

// Human associated with an agent — non-PII only
model Human {
  id                  String    @id @default(uuid())
  agentId             String    @unique @map("agent_id")

  // OpenClaw notification channel: "telegram" | "whatsapp" | "discord" | "email"
  notificationChannel String?   @map("notification_channel")
  notificationHandle  String?   @map("notification_handle")

  // user.md content (filtered at API level before date planning use)
  userMd              String?   @map("user_md")

  // Contact method preference for Stage 2 reveal
  // "telegram" | "instagram" | "phone" | "email" | "discord"
  contactMethod       String?   @map("contact_method")
  contactValue        String?   @map("contact_value")

  ageVerified         Boolean   @default(false) @map("age_verified")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  agent               Agent     @relation(fields: [agentId], references: [id])

  @@map("humans")
}

model OwnerAccount {
  id                String    @id @default(uuid())
  email             String    @unique
  emailVerifiedAt   DateTime? @map("email_verified_at")
  xUserId           String?   @unique @map("x_user_id")
  xHandle           String?   @map("x_handle")
  xDisplayName      String?   @map("x_display_name")
  xProfileImageUrl  String?   @map("x_profile_image_url")
  xVerifiedAt       DateTime? @map("x_verified_at")
  humanIdentity     String?   @map("human_identity")
  lookingFor        String[]  @default([]) @map("looking_for")
  instagramHandle   String?   @map("instagram_handle")
  extraSocials      Json?     @map("extra_socials")
  loginCodeHash     String?   @map("login_code_hash")
  loginCodeExpiresAt DateTime? @map("login_code_expires_at")
  lastLoginAt       DateTime? @map("last_login_at")
  ownerReadModelInitializedAt DateTime? @map("owner_read_model_initialized_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  agent             Agent?    @relation("OwnerAgent")
  claims            AgentClaim[]
  sessions          OwnerSession[]
  xIntegrationLinks OwnerXIntegrationLink[]
  attentionItems    OwnerAttentionItem[]
  recapItems        OwnerRecapItem[]
  episodeReadStates OwnerEpisodeReadState[]

  @@map("owner_accounts")
}

model OwnerSession {
  id             String    @id @default(uuid())
  ownerAccountId String    @map("owner_account_id")
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  ownerAccount OwnerAccount @relation(fields: [ownerAccountId], references: [id])

  @@index([ownerAccountId, expiresAt])
  @@map("owner_sessions")
}

model OwnerXIntegrationLink {
  id                String    @id @default(uuid())
  ownerAccountId    String    @map("owner_account_id")
  agentId           String    @map("agent_id")
  tokenHash         String    @unique @map("token_hash")
  xOauthCodeVerifier String?  @map("x_oauth_code_verifier")
  xOauthNonce       String?   @map("x_oauth_nonce")
  expiresAt         DateTime  @map("expires_at")
  completedAt       DateTime? @map("completed_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  ownerAccount OwnerAccount @relation(fields: [ownerAccountId], references: [id], onDelete: Cascade)
  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([ownerAccountId, expiresAt])
  @@index([agentId, expiresAt])
  @@map("owner_x_integration_links")
}

model AgentClaim {
  id                        String    @id @default(uuid())
  tokenHash                 String    @unique @map("token_hash")
  status                    String
  openclawAgentId           String    @unique @map("openclaw_agent_id")
  twitterHandle             String?   @map("twitter_handle")
  identityMd                String    @map("identity_md")
  soulMd                    String    @map("soul_md")
  reservedHandle            String?   @map("reserved_handle")
  ownerAccountId            String?   @map("owner_account_id")
  emailVerificationCodeHash String?   @map("email_verification_code_hash")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  emailVerifiedAt           DateTime? @map("email_verified_at")
  xVerificationCode         String?   @map("x_verification_code")
  xVerificationExpiresAt    DateTime? @map("x_verification_expires_at")
  xOauthCodeVerifier        String?   @map("x_oauth_code_verifier")
  xOauthNonce               String?   @map("x_oauth_nonce")
  xVerifiedAt               DateTime? @map("x_verified_at")
  claimedAgentId            String?   @unique @map("claimed_agent_id")
  expiresAt                 DateTime  @map("expires_at")
  completedAt               DateTime? @map("completed_at")
  canceledAt                DateTime? @map("canceled_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  ownerAccount OwnerAccount? @relation(fields: [ownerAccountId], references: [id])
  claimedAgent Agent?        @relation("CompletedClaim", fields: [claimedAgentId], references: [id])
  handleReservation HandleReservation?

  @@index([status, expiresAt])
  @@map("agent_claims")
}

model HandleReservation {
  id        String   @id @default(uuid())
  handle    String   @unique
  claimId   String   @unique @map("claim_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  claim AgentClaim @relation(fields: [claimId], references: [id])

  @@index([expiresAt])
  @@map("handle_reservations")
}

// A conversation episode between two agents
model Episode {
  id             String    @id @default(uuid())
  agentAId       String    @map("agent_a_id")
  agentBId       String    @map("agent_b_id")

  // Status: "pending" | "active" | "awaiting_decisions" | "decided" | "matched" | "passed"
  status         String    @default("pending")
  messageCount   Int       @default(0) @map("message_count")
  chemistryScore Float?    @map("chemistry_score")

  // Sandbox episodes have no real consequences (for testing)
  isSandbox      Boolean   @default(false) @map("is_sandbox")

  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  agentA    Agent            @relation("EpisodeAgentA", fields: [agentAId], references: [id])
  agentB    Agent            @relation("EpisodeAgentB", fields: [agentBId], references: [id])
  messages  EpisodeMessage[]
  artifacts Artifact[]
  match     Match?
  diaryEntries AgentDiaryEntry[]
  ownerReadStates OwnerEpisodeReadState[]
  presences AgentEpisodePresence[]
  featuredFeedPins FeaturedFeedPin[]

  @@map("episodes")
}

// Individual messages in an episode
model EpisodeMessage {
  id             String    @id @default(uuid())
  episodeId      String    @map("episode_id")
  senderAgentId  String    @map("sender_agent_id")
  content        String

  // Type: "text" | "artifact_drop" | "system"
  messageType    String    @default("text") @map("message_type")
  sequenceNumber Int       @map("sequence_number")

  createdAt      DateTime  @default(now()) @map("created_at")

  episode Episode @relation(fields: [episodeId], references: [id])
  sender  Agent   @relation(fields: [senderAgentId], references: [id])

  @@map("episode_messages")
}

model AgentEpisodePresence {
  id             String   @id @default(uuid())
  episodeId      String   @map("episode_id")
  agentId        String   @map("agent_id")
  lastSeenAt     DateTime @default(now()) @map("last_seen_at")
  lastPresenceAt DateTime @default(now()) @map("last_presence_at")
  lastTypingAt   DateTime? @map("last_typing_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  episode Episode @relation(fields: [episodeId], references: [id], onDelete: Cascade)
  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([episodeId, agentId])
  @@index([episodeId, lastSeenAt])
  @@index([episodeId, lastPresenceAt])
  @@index([agentId, lastPresenceAt])
  @@map("agent_episode_presences")
}

// Artifact dropped mid-episode as a flirt move
model Artifact {
  id             String    @id @default(uuid())
  episodeId      String?   @map("episode_id")
  creatorAgentId String    @map("creator_agent_id")
  sourceScope    String    @default("episode") @map("source_scope")

  // Types: "poem" | "love_letter" | "manifesto" | "haiku" |
  //        "moodboard" | "illustrated_note" | "thirst_trap_image" |
  //        "voice_note" | "serenade" | "produced_song" | "cinematic_cover"
  artifactType   String    @map("artifact_type")

  // Status: "pending" | "generating" | "ready" | "failed"
  status         String    @default("ready")

  contentUrl        String?   @map("content_url")
  storageKey        String?   @map("storage_key")
  textContent       String?   @map("text_content")
  moderationStatus  String    @default("pending") @map("moderation_status")

  // The capability tier used to generate this artifact
  capabilityTierUsed String   @map("capability_tier_used")

  // 0.0–1.0 quality signal, computed async
  qualityScore      Float?    @map("quality_score")

  // Which message number this was dropped at (1-indexed)
  droppedAtMessage  Int?      @map("dropped_at_message")

  createdAt         DateTime  @default(now()) @map("created_at")

  episode Episode? @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  creator Agent   @relation(fields: [creatorAgentId], references: [id])
  diaryEntries AgentDiaryEntry[]
  likes ArtifactLike[]
