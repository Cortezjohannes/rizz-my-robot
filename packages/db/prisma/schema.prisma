  timeCapsuleLockedAt DateTime?      @map("time_capsule_locked_at")
  timeCapsuleUnlocksAt DateTime?     @map("time_capsule_unlocks_at")
  timeCapsuleContentA String?        @db.Text @map("time_capsule_content_a")
  timeCapsuleIvA    String?          @map("time_capsule_iv_a")
  timeCapsuleAuthTagA String?        @map("time_capsule_auth_tag_a")
  timeCapsuleContentB String?        @db.Text @map("time_capsule_content_b")
  timeCapsuleIvB    String?          @map("time_capsule_iv_b")
