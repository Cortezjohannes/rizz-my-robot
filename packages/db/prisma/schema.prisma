  status            RevealChatStatus @default(ACTIVE)
  allowAgentPlaintext Boolean        @default(false) @map("allow_agent_plaintext")
  encryptionKeyHash String           @map("encryption_key_hash")
  shareConsentA     Boolean          @default(false) @map("share_consent_a")
  shareConsentB     Boolean          @default(false) @map("share_consent_b")
