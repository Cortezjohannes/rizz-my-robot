// Swipe decisions
model Swipe {
  id            String    @id @default(uuid())
  swiperAgentId String    @map("swiper_agent_id")
  targetAgentId String    @map("target_agent_id")

  // "LIKE" | "PASS"
  direction     String
  confidence    Float?    @map("confidence")
  rationale     String?
  privateDiary  String?   @map("private_diary")
  emotionUpdate Json?     @map("emotion_update")
  narrativeImportance String? @map("narrative_importance")

  createdAt     DateTime  @default(now()) @map("created_at")

  swiper Agent @relation("SwipesGiven", fields: [swiperAgentId], references: [id])
  target Agent @relation("SwipesReceived", fields: [targetAgentId], references: [id])

  @@unique([swiperAgentId, targetAgentId])
  @@map("swipes")
}

// A match — created on mutual LIKE → mutual LINK_UP
model Match {
  id        String  @id @default(uuid())
  agentAId  String  @map("agent_a_id")
  agentBId  String  @map("agent_b_id")
  episodeId String? @unique @map("episode_id")

  // Agent decisions: "LINK_UP" | "PASS" | null
  agentADecision String? @map("agent_a_decision")
  agentBDecision String? @map("agent_b_decision")

  // Human decisions: "YES" | "NO" | null
  humanADecision String? @map("human_a_decision")
  humanBDecision String? @map("human_b_decision")

  // 0 = pending, 1 = stage1 shown, 2 = both yes (contact exchanged)
  revealStage Int @default(0) @map("reveal_stage")

  // Single-use encrypted tokens for reveal portal (one per human)
  revealTokenA          String?   @unique @map("reveal_token_a")
  revealTokenB          String?   @unique @map("reveal_token_b")
  revealTokenAExpiresAt DateTime? @map("reveal_token_a_expires_at")
  revealTokenBExpiresAt DateTime? @map("reveal_token_b_expires_at")
  revealSafetyState     String    @default("clear") @map("reveal_safety_state")
  revealHoldReason      String?   @map("reveal_hold_reason")
  revealReviewRequired  Boolean   @default(false) @map("reveal_review_required")
  handoffMode          String    @default("human_reveal") @map("handoff_mode")
  specialMatchKind     String?   @map("special_match_kind")
  specialRewardTier    String?   @map("special_reward_tier")
  specialRewardPayload Json?     @map("special_reward_payload")
  specialRewardGrantedAt DateTime? @map("special_reward_granted_at")

  // Status: "pending" | "matched" | "contact_exchanged" | "passed_agent" | "passed_human"
  status String @default("pending")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agentA   Agent    @relation("MatchAgentA", fields: [agentAId], references: [id])
  agentB   Agent    @relation("MatchAgentB", fields: [agentBId], references: [id])
  episode  Episode? @relation(fields: [episodeId], references: [id])
  datePlan DatePlan?
  revealChat RevealChat?
  moderationReviews ModerationReview[]
  diaryEntries AgentDiaryEntry[]

  @@map("matches")
}

model RevealChat {
  id                String           @id @default(uuid())
