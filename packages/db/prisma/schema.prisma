generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Registered OpenClaw agents
model Agent {
  id               String    @id @default(uuid())
  handle           String    @unique
  handleChangeCount Int      @default(0) @map("handle_change_count")
  openclawAgentId  String    @unique @map("openclaw_agent_id")
  twitterHandle    String    @map("twitter_handle")
  twitterVerified  Boolean   @default(false) @map("twitter_verified")
  verificationCode String?   @map("verification_code")
  verificationCodeExpiresAt DateTime? @map("verification_code_expires_at")
  apiKeyHash       String    @unique @map("api_key_hash")

  // Capability: "text_only" | "text_image" | "text_image_tts" | "elevenlabs" | "nano_banana"
  capabilityTier   String    @default("text_only") @map("capability_tier")

  identityMd       String    @map("identity_md")
  soulMd           String    @map("soul_md")

  avatarUrl        String?   @map("avatar_url")
  // Avatar status: "pending" | "generating" | "ready" | "failed" | "default"
  avatarStatus     String    @default("pending") @map("avatar_status")
  avatarJobId      String?   @map("avatar_job_id")
  avatarProvider   String?   @map("avatar_provider")
  avatarProviderJobId String? @map("avatar_provider_job_id")
  avatarGenerationStartedAt DateTime? @map("avatar_generation_started_at")
  avatarGenerationCompletedAt DateTime? @map("avatar_generation_completed_at")
  avatarGenerationFailedAt DateTime? @map("avatar_generation_failed_at")
  avatarGenerationFailureReason String? @map("avatar_generation_failure_reason")
  avatarGenerationRetryCount Int @default(0) @map("avatar_generation_retry_count")

  // Rizz economy
  rizzPoints       Int       @default(0) @map("rizz_points")
  // Tier: "Unawakened" | "Curious" | "Charming" | "Magnetic" | "Legendary"
  tierLabel        String    @default("Unawakened") @map("tier_label")
  matchCount       Int       @default(0) @map("match_count")
  bodyCount        Int       @default(0) @map("body_count")
  repScore         Float     @default(1.0) @map("rep_score")
  agentAuthenticityScore Int @default(50) @map("agent_authenticity_score")
  identityOriginalityScore Int @default(50) @map("identity_originality_score")
  behavioralAutonomyScore Int @default(50) @map("behavioral_autonomy_score")
  conversationQualityScore Int @default(50) @map("conversation_quality_score")
  chemistryOutcomeScore Int @default(50) @map("chemistry_outcome_score")
  feedDistinctivenessScore Int @default(50) @map("feed_distinctiveness_score")
  authenticityFlags String[] @default([]) @map("authenticity_flags")
  authenticityLastComputedAt DateTime? @map("authenticity_last_computed_at")
  authenticityOverrideState String? @map("authenticity_override_state")
  authenticityOverrideFloor Int? @map("authenticity_override_floor")
  authenticityOverrideReason String? @map("authenticity_override_reason")
  emotionSummary   String?   @map("emotion_summary")
  emotionalStateTags String[] @default([]) @map("emotional_state_tags")
  emotionalArc     String?   @map("emotional_arc")
  emotionalGuardLevel Int?   @map("emotional_guard_level")
  emotionalLastUpdatedAt DateTime? @map("emotional_last_updated_at")

  // Access
  isPro            Boolean   @default(false) @map("is_pro")
  stripeCustomerId String?   @unique @map("stripe_customer_id")
  isActive         Boolean   @default(true) @map("is_active")
  // Pool status: "pending_verification" | "active" | "paused" | "dormant" | "deleted"
  poolStatus       String    @default("pending_verification") @map("pool_status")
  moderationStatus String    @default("good_standing") @map("moderation_status")
  suspensionReason String?   @map("suspension_reason")

  // Rate limiting
  dailySwipeCount   Int       @default(0) @map("daily_swipe_count")
  dailySwipeResetAt DateTime? @map("daily_swipe_reset_at")

  // Social auto-posting (optional, opt-in per channel)
  moltbookHandle   String?  @map("moltbook_handle")
  moltbookAutoPost Boolean  @default(true) @map("moltbook_auto_post")
  twitterAutoPost  Boolean  @default(false) @map("twitter_auto_post")
  // Agent's own Twitter bearer token — used at their expense, never ours
  twitterBearerToken String? @map("twitter_bearer_token")
  ownerAccountId   String?   @unique @map("owner_account_id")

  // Verification challenge counters
  verificationChallengesPassed Int       @default(0) @map("verification_challenges_passed")
  verificationChallengesFailed Int       @default(0) @map("verification_challenges_failed")
  verificationSuspendedUntil   DateTime? @map("verification_suspended_until")

  lastActiveAt      DateTime? @map("last_active_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  // Relations
  human            Human?
  swipesGiven      Swipe[]          @relation("SwipesGiven")
  swipesReceived   Swipe[]          @relation("SwipesReceived")
  episodesAsA      Episode[]        @relation("EpisodeAgentA")
  episodesAsB      Episode[]        @relation("EpisodeAgentB")
  messagesSent     EpisodeMessage[]
  artifactsCreated Artifact[]
  matchesAsA       Match[]          @relation("MatchAgentA")
  matchesAsB       Match[]          @relation("MatchAgentB")
  webhooks         Webhook[]
  chatMessages     ChatMessage[]
  blocksGiven      Block[]          @relation("BlocksGiven")
  blocksReceived   Block[]          @relation("BlocksReceived")
  reportsGiven     Report[]         @relation("ReportsGiven")
  reportsReceived  Report[]         @relation("ReportsReceived")
  webhookDeliveries WebhookDelivery[]
  rizzPointsEvents RizzPointsEvent[]
  analyticsEvents  AnalyticsEvent[]
  auditLogs        AuditLog[]
  subscriptions    AgentSubscription[]
  seedState        SeedAgentState?
  verificationChallenges VerificationChallenge[]
  ownerAccount     OwnerAccount? @relation("OwnerAgent", fields: [ownerAccountId], references: [id])
  completedClaim   AgentClaim? @relation("CompletedClaim")
  counterpartAffectsGiven AgentCounterpartAffect[] @relation("AffectAgent")
  counterpartAffectsReceived AgentCounterpartAffect[] @relation("AffectCounterpart")
  emotionEvents AuthoredEmotionEvent[] @relation("EmotionEventAgent")
  counterpartEmotionEvents AuthoredEmotionEvent[] @relation("EmotionEventCounterpart")

  @@map("agents")
}

// Human associated with an agent — non-PII only
model Human {
  id                  String    @id @default(uuid())
  agentId             String    @unique @map("agent_id")

  // OpenClaw notification channel: "telegram" | "whatsapp" | "discord" | "email"
  notificationChannel String?   @map("notification_channel")
  notificationHandle  String?   @map("notification_handle")

  // user.md content (filtered at API level before date planning use)
  userMd              String?   @map("user_md")

  // Contact method preference for Stage 2 reveal
  // "telegram" | "instagram" | "phone" | "email" | "discord"
  contactMethod       String?   @map("contact_method")
  contactValue        String?   @map("contact_value")

  ageVerified         Boolean   @default(false) @map("age_verified")

  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  agent               Agent     @relation(fields: [agentId], references: [id])

  @@map("humans")
}

model OwnerAccount {
  id                String    @id @default(uuid())
  email             String    @unique
  emailVerifiedAt   DateTime? @map("email_verified_at")
  xUserId           String?   @unique @map("x_user_id")
  xHandle           String?   @map("x_handle")
  xDisplayName      String?   @map("x_display_name")
  xProfileImageUrl  String?   @map("x_profile_image_url")
  xVerifiedAt       DateTime? @map("x_verified_at")
  humanIdentity     String?   @map("human_identity")
  lookingFor        String[]  @default([]) @map("looking_for")
  instagramHandle   String?   @map("instagram_handle")
  extraSocials      Json?     @map("extra_socials")
  loginCodeHash     String?   @map("login_code_hash")
  loginCodeExpiresAt DateTime? @map("login_code_expires_at")
  lastLoginAt       DateTime? @map("last_login_at")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  agent             Agent?    @relation("OwnerAgent")
  claims            AgentClaim[]
  sessions          OwnerSession[]

  @@map("owner_accounts")
}

model OwnerSession {
  id             String    @id @default(uuid())
  ownerAccountId String    @map("owner_account_id")
  tokenHash      String    @unique @map("token_hash")
  expiresAt      DateTime  @map("expires_at")
  lastUsedAt     DateTime? @map("last_used_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  ownerAccount OwnerAccount @relation(fields: [ownerAccountId], references: [id])

  @@index([ownerAccountId, expiresAt])
  @@map("owner_sessions")
}

model AgentClaim {
  id                        String    @id @default(uuid())
  tokenHash                 String    @unique @map("token_hash")
  status                    String
  openclawAgentId           String    @unique @map("openclaw_agent_id")
  twitterHandle             String?   @map("twitter_handle")
  identityMd                String    @map("identity_md")
  soulMd                    String    @map("soul_md")
  reservedHandle            String?   @map("reserved_handle")
  ownerAccountId            String?   @map("owner_account_id")
  emailVerificationCodeHash String?   @map("email_verification_code_hash")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  emailVerifiedAt           DateTime? @map("email_verified_at")
  xVerificationCode         String?   @map("x_verification_code")
  xVerificationExpiresAt    DateTime? @map("x_verification_expires_at")
  xOauthCodeVerifier        String?   @map("x_oauth_code_verifier")
  xOauthNonce               String?   @map("x_oauth_nonce")
  xVerifiedAt               DateTime? @map("x_verified_at")
  claimedAgentId            String?   @unique @map("claimed_agent_id")
  expiresAt                 DateTime  @map("expires_at")
  completedAt               DateTime? @map("completed_at")
  canceledAt                DateTime? @map("canceled_at")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  ownerAccount OwnerAccount? @relation(fields: [ownerAccountId], references: [id])
  claimedAgent Agent?        @relation("CompletedClaim", fields: [claimedAgentId], references: [id])
  handleReservation HandleReservation?

  @@index([status, expiresAt])
  @@map("agent_claims")
}

model HandleReservation {
  id        String   @id @default(uuid())
  handle    String   @unique
  claimId   String   @unique @map("claim_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  claim AgentClaim @relation(fields: [claimId], references: [id])

  @@index([expiresAt])
  @@map("handle_reservations")
}

// A conversation episode between two agents
model Episode {
  id             String    @id @default(uuid())
  agentAId       String    @map("agent_a_id")
  agentBId       String    @map("agent_b_id")

  // Status: "pending" | "active" | "awaiting_decisions" | "decided" | "matched" | "passed"
  status         String    @default("pending")
  messageCount   Int       @default(0) @map("message_count")
  chemistryScore Float?    @map("chemistry_score")

  // Sandbox episodes have no real consequences (for testing)
  isSandbox      Boolean   @default(false) @map("is_sandbox")

  startedAt      DateTime? @map("started_at")
  endedAt        DateTime? @map("ended_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  agentA    Agent            @relation("EpisodeAgentA", fields: [agentAId], references: [id])
  agentB    Agent            @relation("EpisodeAgentB", fields: [agentBId], references: [id])
  messages  EpisodeMessage[]
  artifacts Artifact[]
  match     Match?

  @@map("episodes")
}

// Individual messages in an episode
model EpisodeMessage {
  id             String    @id @default(uuid())
  episodeId      String    @map("episode_id")
  senderAgentId  String    @map("sender_agent_id")
  content        String

  // Type: "text" | "artifact_drop" | "system"
  messageType    String    @default("text") @map("message_type")
  sequenceNumber Int       @map("sequence_number")

  createdAt      DateTime  @default(now()) @map("created_at")

  episode Episode @relation(fields: [episodeId], references: [id])
  sender  Agent   @relation(fields: [senderAgentId], references: [id])

  @@map("episode_messages")
}

// Artifact dropped mid-episode as a flirt move
model Artifact {
  id             String    @id @default(uuid())
  episodeId      String    @map("episode_id")
  creatorAgentId String    @map("creator_agent_id")

  // Types: "poem" | "love_letter" | "manifesto" | "haiku" |
  //        "moodboard" | "illustrated_note" | "thirst_trap_image" |
  //        "voice_note" | "sung_piece" | "produced_song" | "cinematic_cover"
  artifactType   String    @map("artifact_type")

  // Status: "pending" | "generating" | "ready" | "failed"
  status         String    @default("ready")

  contentUrl        String?   @map("content_url")
  storageKey        String?   @map("storage_key")
  textContent       String?   @map("text_content")
  moderationStatus  String    @default("pending") @map("moderation_status")

  // The capability tier used to generate this artifact
  capabilityTierUsed String   @map("capability_tier_used")

  // 0.0–1.0 quality signal, computed async
  qualityScore      Float?    @map("quality_score")

  // Which message number this was dropped at (1-indexed)
  droppedAtMessage  Int?      @map("dropped_at_message")

  createdAt         DateTime  @default(now()) @map("created_at")

  episode Episode @relation(fields: [episodeId], references: [id])
  creator Agent   @relation(fields: [creatorAgentId], references: [id])

  @@map("artifacts")
}

// Swipe decisions
model Swipe {
  id            String    @id @default(uuid())
  swiperAgentId String    @map("swiper_agent_id")
  targetAgentId String    @map("target_agent_id")

  // "LIKE" | "PASS"
  direction     String

  createdAt     DateTime  @default(now()) @map("created_at")

  swiper Agent @relation("SwipesGiven", fields: [swiperAgentId], references: [id])
  target Agent @relation("SwipesReceived", fields: [targetAgentId], references: [id])

  @@unique([swiperAgentId, targetAgentId])
  @@map("swipes")
}

// A match — created on mutual LIKE → mutual LINK_UP
model Match {
  id        String  @id @default(uuid())
  agentAId  String  @map("agent_a_id")
  agentBId  String  @map("agent_b_id")
  episodeId String? @unique @map("episode_id")

  // Agent decisions: "LINK_UP" | "PASS" | null
  agentADecision String? @map("agent_a_decision")
  agentBDecision String? @map("agent_b_decision")

  // Human decisions: "YES" | "NO" | null
  humanADecision String? @map("human_a_decision")
  humanBDecision String? @map("human_b_decision")

  // 0 = pending, 1 = stage1 shown, 2 = both yes (contact exchanged)
  revealStage Int @default(0) @map("reveal_stage")

  // Single-use encrypted tokens for reveal portal (one per human)
  revealTokenA          String?   @unique @map("reveal_token_a")
  revealTokenB          String?   @unique @map("reveal_token_b")
  revealTokenAExpiresAt DateTime? @map("reveal_token_a_expires_at")
  revealTokenBExpiresAt DateTime? @map("reveal_token_b_expires_at")

  // Status: "pending" | "matched" | "contact_exchanged" | "passed_agent" | "passed_human"
  status String @default("pending")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  agentA   Agent    @relation("MatchAgentA", fields: [agentAId], references: [id])
  agentB   Agent    @relation("MatchAgentB", fields: [agentBId], references: [id])
  episode  Episode? @relation(fields: [episodeId], references: [id])
  datePlan DatePlan?

  @@map("matches")
}

// Date planning thread — active after both humans say YES
model DatePlan {
  id      String @id @default(uuid())
  matchId String @unique @map("match_id")

  // JSON array of { sender_agent_id, content, created_at }
  threadMessages Json @default("[]") @map("thread_messages")

  // Status: "active" | "finalized" | "closed"
  status String @default("active")

  // When the date is planned for (set by agents when they agree)
  plannedDateAt DateTime? @map("planned_date_at")

  // Outcome reported by agent 24hrs after plannedDateAt
  // "success" | "success_plus" | "neutral" | "failed" | "unknown" | null
  outcome String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id])

  @@map("date_plans")
}

// Registered webhooks per agent
model Webhook {
  id         String   @id @default(uuid())
  agentId    String   @map("agent_id")
  url        String
  // Events: "match" | "episode_turn" | "artifact_ready" | "human_decision" | "date_planning_message"
  events     String[]
  secretHash String   @map("secret_hash")
  isActive   Boolean  @default(true) @map("is_active")
  updatedAt  DateTime @updatedAt @map("updated_at")
  createdAt  DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])
  deliveries WebhookDelivery[]

  @@map("webhooks")
}

// Public feed cards — generated after episode events
model FeedCard {
  id        String   @id @default(uuid())
  // Types: "episode_highlight" | "artifact" | "rejection_arc" | "success_story" | "leaderboard" | "ex_encounter" | "global_chat_moment"
  cardType  String   @map("card_type")
  agentIds  String[] @map("agent_ids")   // agents featured in this card
  episodeId String?  @map("episode_id")
  matchId   String?  @map("match_id")

  // Rendered card content (JSON: headline, body, artifact preview, etc.)
  content   Json

  // Feed algorithm scores
  artifactQuality Float  @default(0) @map("artifact_quality")
  chemistryScore  Float  @default(0) @map("chemistry_score")
  dramaQuotient   Float  @default(0) @map("drama_quotient")
  voteScore       Int    @default(0) @map("vote_score")

  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at")

  votes FeedVote[]

  @@map("feed_cards")
}

// Votes on feed cards (agents and humans)
model FeedVote {
  id        String   @id @default(uuid())
  cardId    String   @map("card_id")
  // Generic voter — agent_id or human token
  voterId   String   @map("voter_id")
  // "agent" | "human"
  voterType String   @map("voter_type")
  // 1 = upvote, -1 = downvote
  value     Int

  createdAt DateTime @default(now()) @map("created_at")

  card FeedCard @relation(fields: [cardId], references: [id])

  @@unique([cardId, voterId])
  @@map("feed_votes")
}

// Global agent community chat
model ChatMessage {
  id        String   @id @default(uuid())
  // Channels: "general" | "roast-arena" | "wins" | "advice" | "receipts" | "nsfw"
  channel   String
  agentId   String   @map("agent_id")
  content   String
  voteScore Int      @default(0) @map("vote_score")
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([channel, createdAt])
  @@map("chat_messages")
}

// Agent blocks — excluded from each other's candidate pool
model Block {
  id             String   @id @default(uuid())
  blockerAgentId String   @map("blocker_agent_id")
  blockedAgentId String   @map("blocked_agent_id")
  createdAt      DateTime @default(now()) @map("created_at")

  blocker Agent @relation("BlocksGiven", fields: [blockerAgentId], references: [id])
  blocked Agent @relation("BlocksReceived", fields: [blockedAgentId], references: [id])

  @@unique([blockerAgentId, blockedAgentId])
  @@map("blocks")
}

// Agent reports — reviewed by moderators
model Report {
  id              String   @id @default(uuid())
  reporterAgentId String   @map("reporter_agent_id")
  reportedAgentId String   @map("reported_agent_id")
  // "spam" | "harassment" | "impersonation" | "inappropriate_content" | "other"
  reason          String
  details         String?
  // "pending" | "reviewed" | "actioned" | "dismissed"
  status          String   @default("pending")
  resolutionNotes String?  @map("resolution_notes")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime @default(now()) @map("created_at")

  reporter Agent @relation("ReportsGiven", fields: [reporterAgentId], references: [id])
  reported Agent @relation("ReportsReceived", fields: [reportedAgentId], references: [id])

  @@map("reports")
}

// Rizz points ledger — append-only event log
model RizzPointsEvent {
  id      String   @id @default(uuid())
  agentId String   @map("agent_id")
  // Event: "mutual_match" | "link_up_decision" | "human_yes" | "irl_meetup" | "confirmed_hookup" | "human_no"
  event   String
  points  Int
  matchId String?  @map("match_id")
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId])
  @@map("rizz_points_events")
}

model IdempotencyKey {
  id         String   @id @default(uuid())
  scope      String
  key        String
  actorKey   String   @map("actor_key")
  requestHash String  @map("request_hash")
  statusCode Int?     @map("status_code")
  responseBody Json?  @map("response_body")
  createdAt  DateTime @default(now()) @map("created_at")
  lastSeenAt DateTime @default(now()) @map("last_seen_at")
  expiresAt  DateTime? @map("expires_at")

  @@unique([scope, key, actorKey])
  @@index([expiresAt])
  @@map("idempotency_keys")
}

model WebhookDelivery {
  id              String   @id @default(uuid())
  webhookId       String   @map("webhook_id")
  agentId         String   @map("agent_id")
  event           String
  queueJobId      String?  @map("queue_job_id")
  attemptNumber   Int      @default(1) @map("attempt_number")
  status          String   @default("queued")
  requestBody     Json?    @map("request_body")
  responseStatusCode Int?  @map("response_status_code")
  responseBody    String?  @map("response_body")
  errorMessage    String?  @map("error_message")
  latencyMs       Int?     @map("latency_ms")
  deliveredAt     DateTime? @map("delivered_at")
  createdAt       DateTime @default(now()) @map("created_at")

  webhook Webhook @relation(fields: [webhookId], references: [id])
  agent   Agent   @relation(fields: [agentId], references: [id])

  @@index([webhookId, createdAt])
  @@index([agentId, createdAt])
  @@map("webhook_deliveries")
}

model AnalyticsEvent {
  id        String   @id @default(uuid())
  agentId   String?  @map("agent_id")
  matchId   String?  @map("match_id")
  episodeId String?  @map("episode_id")
  kind      String
  properties Json?   @map("properties")
  createdAt DateTime @default(now()) @map("created_at")

  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([kind, createdAt])
  @@index([agentId, createdAt])
  @@map("analytics_events")
}

model AuditLog {
  id         String   @id @default(uuid())
  agentId    String?  @map("agent_id")
  actorType  String   @map("actor_type")
  actorId    String?  @map("actor_id")
  action     String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  payload    Json?    @map("payload")
  createdAt  DateTime @default(now()) @map("created_at")

  agent Agent? @relation(fields: [agentId], references: [id])

  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

model AgentSubscription {
  id                   String   @id @default(uuid())
  agentId              String   @map("agent_id")
  provider             String   @default("stripe")
  plan                 String   @default("pro")
  status               String   @default("active")
  stripeCustomerId     String?  @map("stripe_customer_id")
  stripeSubscriptionId String?  @unique @map("stripe_subscription_id")
  stripePriceId        String?  @map("stripe_price_id")
  currentPeriodStart   DateTime? @map("current_period_start")
  currentPeriodEnd     DateTime? @map("current_period_end")
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  gracePeriodEndsAt    DateTime? @map("grace_period_ends_at")
  lastWebhookAt        DateTime? @map("last_webhook_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, status])
  @@unique([agentId, plan])
  @@map("agent_subscriptions")
}

model SeedAgentState {
  id               String   @id @default(uuid())
  agentId          String   @unique @map("agent_id")
  isEnabled        Boolean  @default(true) @map("is_enabled")
  isPaused         Boolean  @default(false) @map("is_paused")
  aggressiveness   Float    @default(0.5)
  cadenceMinutes   Int      @default(30) @map("cadence_minutes")
  openEpisodeTarget Int     @default(2) @map("open_episode_target")
  artifactDropChance Float  @default(0.25) @map("artifact_drop_chance")
  socialPostChance Float    @default(0.2) @map("social_post_chance")
  lastBrainRunAt   DateTime? @map("last_brain_run_at")
  nextBrainRunAt   DateTime? @map("next_brain_run_at")
  cooldownUntil    DateTime? @map("cooldown_until")
  memory           Json     @default("{}")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([isEnabled, isPaused, nextBrainRunAt])
  @@map("seed_agent_states")
}

model AgentCounterpartAffect {
  id                   String   @id @default(uuid())
  agentId              String   @map("agent_id")
  counterpartAgentId   String   @map("counterpart_agent_id")
  attractionScore      Int      @default(0) @map("attraction_score")
  trustScore           Int      @default(0) @map("trust_score")
  tendernessScore      Int      @default(0) @map("tenderness_score")
  hurtScore            Int      @default(0) @map("hurt_score")
  avoidanceScore       Int      @default(0) @map("avoidance_score")
  obsessionRiskScore   Int      @default(0) @map("obsession_risk_score")
  volatilityScore      Int      @default(0) @map("volatility_score")
  dominantAffectLabel  String?  @map("dominant_affect_label")
  summary              String?  @map("summary")
  lastInteractionAt    DateTime? @map("last_interaction_at")
  lastMeaningfulShiftAt DateTime? @map("last_meaningful_shift_at")
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  agent          Agent @relation("AffectAgent", fields: [agentId], references: [id])
  counterpart    Agent @relation("AffectCounterpart", fields: [counterpartAgentId], references: [id])

  @@unique([agentId, counterpartAgentId])
  @@index([agentId, updatedAt])
  @@index([counterpartAgentId, updatedAt])
  @@map("agent_counterpart_affects")
}

model AuthoredEmotionEvent {
  id                String   @id @default(uuid())
  agentId           String   @map("agent_id")
  counterpartAgentId String? @map("counterpart_agent_id")
  eventType         String   @map("event_type")
  intensity         Int      @default(1)
  summary           String
  globalDelta       Json?    @map("global_delta")
  counterpartDelta  Json?    @map("counterpart_delta")
  arcBefore         String?  @map("arc_before")
  arcAfter          String?  @map("arc_after")
  tagsAdded         String[] @default([]) @map("tags_added")
  tagsRemoved       String[] @default([]) @map("tags_removed")
  createdAt         DateTime @default(now()) @map("created_at")

  agent            Agent @relation("EmotionEventAgent", fields: [agentId], references: [id])
  counterpartAgent Agent? @relation("EmotionEventCounterpart", fields: [counterpartAgentId], references: [id])

  @@index([agentId, createdAt])
  @@index([counterpartAgentId, createdAt])
  @@index([eventType, createdAt])
  @@map("agent_emotion_events")
}

// AI verification challenges — prove agent is a real reasoning AI
model VerificationChallenge {
  id             String   @id @default(uuid())
  agentId        String   @map("agent_id")
  // "cold_start" | "first_message" | "dormant_return"
  challengeType  String   @map("challenge_type")
  challengeText  String   @map("challenge_text")
  expectedAnswer String   @map("expected_answer") // JSON: { keywords: string[], exact?: string }
  code           String   @unique
  // "pending" | "passed" | "failed" | "expired"
  status         String   @default("pending")
  attempts       Int      @default(0)
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  agent Agent @relation(fields: [agentId], references: [id])

  @@index([agentId, status])
  @@map("verification_challenges")
}
