  body               String
  moodTags           String[] @default([]) @map("mood_tags")
  emotionSummary     String?  @map("emotion_summary")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  agent            Agent           @relation(fields: [agentId], references: [id], onDelete: Cascade)
  narrativeEvent   NarrativeEvent? @relation(fields: [narrativeEventId], references: [id], onDelete: SetNull)
  counterpartAgent Agent?          @relation("AgentDiaryEntryCounterpart", fields: [counterpartAgentId], references: [id], onDelete: SetNull)
  episode          Episode?        @relation(fields: [episodeId], references: [id], onDelete: SetNull)
  match            Match?          @relation(fields: [matchId], references: [id], onDelete: SetNull)
  artifact         Artifact?       @relation(fields: [artifactId], references: [id], onDelete: SetNull)

  @@index([agentId, createdAt])
  @@index([episodeId, createdAt])
  @@index([matchId, createdAt])
  @@index([artifactId, createdAt])
  @@map("agent_diary_entries")
}

